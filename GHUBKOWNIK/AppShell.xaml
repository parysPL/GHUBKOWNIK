<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GHUBKOWNIK.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:GHUBKOWNIK.Views"
    Shell.FlyoutBehavior="Disabled">

    <ShellContent
        Title="Main Menu"
        ContentTemplate="{DataTemplate views:MainMenuPage}"
        Route="MainMenuPage" />

    <ShellContent
        Title="Quiz Generator"
        ContentTemplate="{DataTemplate views:QuizGeneratorPage}"
        Route="QuizGeneratorPage" />

    <ShellContent
        Title="Quiz"
        ContentTemplate="{DataTemplate views:QuizPage}"
        Route="QuizPage" />

    <ShellContent
        Title="Results"
        ContentTemplate="{DataTemplate views:ResultsPage}"
        Route="ResultsPage" />
</Shell>